# Postgres connection string — adjust host/port if not using docker-compose.
TASKQ_PG_DSN=postgresql://taskq:taskq@localhost:5432/taskq

# Redis URL — leave unset to run without Redis (rate limits fall back to PG).
TASKQ_REDIS_URL=redis://localhost:6379

# Environment label shown in the admin UI header.
TASKQ_ENVIRONMENT=dev

# URL where the admin sidecar is reachable from the user's browser.
# Must match the host/port where the admin service is exposed.
TASKQ_ADMIN_URL=http://localhost:8001

# Bind address for the admin sidecar uvicorn process (inside the container).
TASKQ_ADMIN_HOST=0.0.0.0

# Bind port for the admin sidecar uvicorn process (inside the container).
TASKQ_ADMIN_PORT=8001

# Bind address for the example trigger app uvicorn process (inside the container).
TASKQ_EXAMPLE_HOST=0.0.0.0

# Bind port for the example trigger app uvicorn process (inside the container).
TASKQ_EXAMPLE_PORT=8000

# Comma-separated queue names the worker consumes from.
TASKQ_QUEUES=examples
