# Copy to .env and adjust for local development.
# `.env` is gitignored; never commit secrets.
# See docs/guides/configuration.md for the full reference.

# ── Required ──────────────────────────────────────────────────────────────

# Direct PG DSN (no PgBouncer). Sessions, LISTEN/NOTIFY, advisory locks need this.
TASKQ_PG_DSN=postgresql://taskq:taskq@localhost:5432/taskq

# ── Optional ──────────────────────────────────────────────────────────────

# Schema name for all TaskQ tables. Defaults to "taskq".
# TASKQ_SCHEMA_NAME=taskq

# Redis URL for real-time progress fanout and admin UI live updates.
# TASKQ_REDIS_URL=redis://localhost:6379/0

# Deployment label. Set to "dev" or "development" to suppress the
# unauthenticated-admin warning banner.
# TASKQ_ENVIRONMENT=dev

# Apply pending migrations on startup. When True, migrations run before the
# admin UI or worker accepts work.  Aborts startup if migrations fail.
# TASKQ_MIGRATE_ON_START=false
